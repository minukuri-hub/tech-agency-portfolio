<!-- UPDATED VERSION -->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modern Digital Agency</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: 'Poppins', sans-serif;
}

body{
    background:#0f172a;
    color:#e5e7eb;
}

/* Navbar */
nav{
    background:#020617;
    padding:15px 60px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

nav h2{
    color:#22c55e;
}

nav a{
    color:#cbd5f5;
    margin-left:20px;
    text-decoration:none;
}

nav a:hover{
    color:#22c55e;
}

/* Hero */
.hero{
    background:linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
    url("https://images.unsplash.com/photo-1522202176988-66273c2fd55f");
    background-size:cover;
    background-position:center;
    text-align:center;
    padding:140px 20px;
}

.hero h1{
    font-size:48px;
    margin-bottom:15px;
}

.hero p{
    font-size:18px;
    margin-bottom:25px;
}

.btn{
    padding:12px 25px;
    border:none;
    border-radius:8px;
    cursor:pointer;
}

.btn-primary{
    background:#22c55e;
    color:white;
}

/* Services */
section{
    padding:80px 20px;
    text-align:center;
}

.section-title{
    font-size:30px;
    margin-bottom:40px;
}

.services{
    display:flex;
    gap:25px;
    justify-content:center;
    flex-wrap:wrap;
}

.card{
    background:#1e293b;
    width:300px;
    border-radius:15px;
    overflow:hidden;
    transition:0.3s;
}

.card:hover{
    transform:translateY(-8px);
}

.card img{
    width:100%;
    height:200px;
    object-fit:cover;
}

.card-content{
    padding:20px;
}

/* About */
.about{
    display:flex;
    flex-wrap:wrap;
    gap:40px;
    align-items:center;
    justify-content:center;
}

.about img{
    width:400px;
    border-radius:15px;
}

/* Contact */
.contact{
    background:#020617;
}

input, textarea{
    width:100%;
    padding:10px;
    margin:10px 0;
    border-radius:6px;
    border:none;
}

footer{
    text-align:center;
    padding:20px;
    background:#020617;
}
</style>
</head>

<body>

<nav>
    <h2>NextGen Tech</h2>
    <div>
        <a href="#">Home</a>
        <a href="#">Services</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </div>
</nav>

<div class="hero">
    <h1>Transform Your Business Digitally</h1>
    <p>We create powerful digital experiences that drive growth</p>
    <button class="btn btn-primary">Start Now</button>
</div>

<section>
    <h2 class="section-title">Our Services</h2>

    <div class="services">

        <div class="card">
            <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085">
            <div class="card-content">
                <h3>Web Development</h3>
                <p>Fast, responsive & scalable websites.</p>
            </div>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1559027615-cd4628902d4a">
            <div class="card-content">
                <h3>Mobile Apps</h3>
                <p>Android & iOS apps with modern UI.</p>
            </div>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f">
            <div class="card-content">
                <h3>Marketing</h3>
                <p>SEO & digital strategies that convert.</p>
            </div>
        </div>

    </div>
</section>

<section class="about">
    <img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d">

    <div>
        <h2>About Us</h2>
        <p>
            Hi, I'm chandrashekerreddy. We help businesses grow using technology,
            creativity, and smart strategies.
        </p>
    </div>
</section>

<section class="contact">
    <h2>Contact</h2>
    <form>
        <input type="text" placeholder="Name">
        <input type="email" placeholder="Email">
        <textarea placeholder="Message"></textarea>
        <button class="btn btn-primary">Send</button>
    </form>
</section>

<footer>
    © 2026 chandrasheker reddy - All rights reserved.
</footer>


</body>
</html>
